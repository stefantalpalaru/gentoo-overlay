         DEPENDS ${kernel_sources})
     else()
       add_custom_command(
         OUTPUT ${cuda_file}
-        COMMAND ${cuda_nvcc_executable} ${_cuda_nvcc_args}
+        COMMAND nvcc ${_cuda_nvcc_args}
         DEPENDS ${kernel_sources})
     endif()
 
